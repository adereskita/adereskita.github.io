---
import ProjectCard from './ProjectCard.astro';
import wondrIcon from '../assets/wondr-icon.png';
import mytelkomselIcon from '../assets/mytelkomsel-icon.png';
import chatajaIcon from '../assets/chataja-icon.jpg';

const projects = [
  {
    name: "Wondr by BNI",
    description: "Large scale banking app feature development and production stability as PGLS sub lead.",
    image: wondrIcon,
    tags: ["Swift", "Modular", "VIPER", "RxSwift", "Crashlytics", "Jenkins"],
  },
    {
    name: "MyTelkomsel",
    description: "Enterprise attendance app built with VIP Clean Architecture.",
    image: mytelkomselIcon,
    tags: ["Swift", "MVVM", "MVC", "RxSwift", "Analytics"],
  },
  {
    name: "Phincon Attendance",
    description: "Enterprise attendance app built with VIP Clean Architecture.",
    emoji: "📋",
    tags: ["Swift", "VIP", "Clean Architecture"],
  },
    {
    name: "ChatAja!",
    description: "Enterprise attendance app built with VIP Clean Architecture.",
    image: chatajaIcon,
    tags: ["Swift", "VIPER", "Reactive Programming"],
  },
  {
    name: "Game Katalog",
    description: "iOS game catalog app Dicoding iOS Developer Expert certification project.",
    emoji: "🎮",
    tags: ["Swift", "Combine", "Core Data", "Clean Architecture"],
  },
  {
    name: "Smart Care",
    description: "IoT health monitoring app 3rd Place at OLIVIA 2019 competition.",
    emoji: "❤️‍🩹",
    tags: ["Web & Mobile", "IoT", "Bluetooth", "HealthKit", "Arduino"],
  },
  {
    name: "Shape You",
    description: "Fitness tracking app published on Google Play Store.",
    emoji: "💪",
    tags: ["Java", "Android", "Firebase", "Google Fit"],
  },
  {
    name: "Cegah Covid-19",
    description: "Web and Android application for COVID-19 information and prevention.",
    emoji: "🛡️",
    tags: ["PHP Laravel", "Android", "SQL", "REST API"],
  },
];
---

<section id="projects">
  <h2 class="text-sm tracking-[0.3em] uppercase text-gray-400 mb-8 font-light">Featured Works</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((p) => (
      <ProjectCard title={p.name} description={p.description} emoji={p.emoji} image={p.image?.src} tags={p.tags} />
    ))}
  </div>
</section>
