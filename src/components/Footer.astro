---
const linkedInIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>`;

const links = [
  { label: "Email", href: "mailto:ade.reskita@gmail.com", icon: "✉️" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/adereskita/", icon: linkedInIcon },
  { label: "GitHub", href: "https://github.com/adereskita", icon: "🐙" },
];
---

<footer class="py-12 px-4 text-center">
  <!-- Dock-style links -->
  <div class="flex justify-center gap-6 mb-8">
    {links.map((link) => (
      <a
        href={link.href}
        target={link.href.startsWith("mailto") ? undefined : "_blank"}
        rel={link.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
        class="glass-card px-5 py-3 flex items-center gap-2 text-sm text-white/80 hover:text-white transition-colors relative overflow-hidden"
      >
        <div class="glare"></div>
        <Fragment set:html={link.icon} />
        <span class="relative z-10">{link.label}</span>
      </a>
    ))}
  </div>

  <p class="text-gray-400/40 text-xs">© 2026 Ade Reskita</p>
</footer>
