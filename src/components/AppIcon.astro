---
interface Props {
  emoji: string;
  size?: 'sm' | 'md';
}

const { emoji, size = 'md' } = Astro.props;
const sizeClasses = size === 'sm' ? 'w-12 h-12 text-2xl rounded-xl' : 'w-16 h-16 text-3xl rounded-2xl';
---

<div class:list={["glass-panel flex items-center justify-center shrink-0", sizeClasses]}>
  <span>{emoji}</span>
</div>
